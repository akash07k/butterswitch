{
  "name": "@butterswitch/log-server",
  "version": "1.0.0",
  "description": "WebSocket log server with accessible web viewer for ButterSwitch.",
  "author": "Akash Kakkar (https://github.com/akash07k/)",
  "license": "AGPL-3.0-only",
  "type": "module",
  "bin": {
    "butterswitch-log-server": "./dist/bin.js"
  },
  "scripts": {
    "build": "vite build && vite build --config vite.web.config.ts",
    "build:cli": "vite build",
    "build:web": "vite build --config vite.web.config.ts",
    "dev": "tsx src/bin.ts",
    "dev:web": "vite --config vite.web.config.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@react-aria/live-announcer": "^3.4.4",
    "commander": "^14.0.3",
    "react": "^19.2.4",
    "react-aria": "^3.47.0",
    "react-aria-components": "^1.16.0",
    "react-dom": "^19.2.4",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.1",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  }
}
