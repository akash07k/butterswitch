{
  "name": "butterswitch-extension",
  "description": "Audio feedback browser extension — sounds for tabs, bookmarks, downloads, and navigation. A richer browsing experience for everyone.",
  "author": "Akash Kakkar (https://github.com/akash07k/)",
  "license": "AGPL-3.0-only",
  "homepage": "https://github.com/akash07k/butterswitch",
  "private": true,
  "version": "1.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n chrome,firefox -c blue,green \"pnpm dev:chrome\" \"pnpm dev:firefox\"",
    "dev:chrome": "node scripts/build-whats-new.mjs && wxt",
    "dev:firefox": "node scripts/build-whats-new.mjs && wxt -b firefox",
    "build": "pnpm build:chrome && pnpm build:firefox",
    "build:chrome": "node scripts/build-whats-new.mjs && wxt build",
    "build:firefox": "node scripts/build-whats-new.mjs && wxt build -b firefox",
    "zip": "pnpm zip:chrome && pnpm zip:firefox",
    "zip:chrome": "node scripts/build-whats-new.mjs && wxt zip",
    "zip:firefox": "node scripts/build-whats-new.mjs && wxt zip -b firefox",
    "submit:init": "wxt-publish-extension init",
    "submit:dry-run": "node scripts/submit.mjs --dry-run",
    "submit": "node scripts/submit.mjs",
    "submit:chrome": "node scripts/submit.mjs --chrome-only",
    "submit:firefox": "node scripts/submit.mjs --firefox-only",
    "release": "release-it",
    "release:dry": "release-it --dry-run",
    "release:push": "git push --follow-tags origin main",
    "do-release": "pnpm release && pnpm release:push",
    "typecheck": "tsc --noEmit",
    "prepare:clean-types": "node scripts/prepare-clean-types.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf .output .wxt",
    "postinstall": "node scripts/postinstall.mjs"
  },
  "dependencies": {
    "@butterswitch/logger": "workspace:*",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-switch": "^1.2.6",
    "@react-aria/live-announcer": "^3.5.0",
    "@tailwindcss/vite": "^4.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "hotkeys-js": "^4.0.3",
    "howler": "^2.2.4",
    "lucide-react": "^1.11.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4"
  },
  "devDependencies": {
    "@release-it/conventional-changelog": "^11.0.0",
    "@types/chrome": "^0.1.40",
    "concurrently": "^9.0.0",
    "@types/howler": "^2.2.12",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@wxt-dev/module-react": "^1.2.2",
    "jsdom": "^29.0.2",
    "release-it": "^20.0.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5",
    "wxt": "^0.20.25"
  }
}
